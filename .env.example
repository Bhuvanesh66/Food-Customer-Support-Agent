# ─────────────────────────────────────────────────────────────
# Synapse AI — environment variables (server reads these)
# Copy this file to `.env` and fill in the keys you have.
# At minimum set GEMINI_API_KEY (also used for embeddings).
# More provider keys = more rotation headroom = fewer rate-limit stalls.
# ─────────────────────────────────────────────────────────────

# Server
PORT=8787
CLIENT_ORIGIN=http://localhost:5173

# Google Gemini  (REQUIRED — used for embeddings + generation)
# Get one free: https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_CHAT_MODEL=gemini-2.5-flash
GEMINI_EMBED_MODEL=gemini-embedding-001
GEMINI_EMBED_DIM=768

# Groq  (OpenAI-compatible) — https://console.groq.com/keys
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# OpenRouter (OpenAI-compatible, free models incl. Kimi) — https://openrouter.ai/keys
OPENROUTER_API_KEY=
OPENROUTER_MODEL=meta-llama/llama-4-scout:free

# NVIDIA NIM (OpenAI-compatible) — https://build.nvidia.com (key starts with nvapi-)
NVIDIA_API_KEY=
NVIDIA_MODEL=meta/llama-3.3-70b-instruct

# Agent tuning (optional — sensible defaults baked in)
ESCALATE_THRESHOLD=0.45
RETRIEVAL_FLOOR=0.55
MAX_AGENT_ITERATIONS=4
