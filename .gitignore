node_modules/
dist/
build/
# Exception: commit the prebuilt client so memory-limited hosts (Render free)
# don't have to run the heavy Vite+Three.js build (which exceeds 512MB).
!client/dist/
!client/dist/**
.env
.env.local
# Commit a pre-seeded app.db so the deploy host does NOT run the memory-heavy
# embedding/seed step at startup (fixes Render free 512MB OOM). The -wal/-shm
# runtime companions stay ignored.
data/*.db-wal
data/*.db-shm
*.log
.DS_Store
.vite/
